# Cognitive Core — Environment Variables
#
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.

# ── LLM Provider ─────────────────────────────────────────────────
# Required for live workflow execution. Not required for mechanism
# tests or simulated execution.

LLM_PROVIDER=google                    # google | openai | azure_openai
GOOGLE_API_KEY=                        # if LLM_PROVIDER=google
OPENAI_API_KEY=                        # if LLM_PROVIDER=openai
AZURE_OPENAI_API_KEY=                  # if LLM_PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=                 # if LLM_PROVIDER=azure_openai
AZURE_OPENAI_DEPLOYMENT=               # if LLM_PROVIDER=azure_openai

# ── Governance ────────────────────────────────────────────────────
CC_PII_ENABLED=false                   # Enable PII redaction before LLM calls
CC_SHADOW_MODE=false                   # Log govern steps without executing
CC_KILL_SWITCH=false                   # Emergency stop for all govern execution
CC_SPEC_LOCK_ENABLED=false             # Lock workflow/domain specs at instance creation

# ── Data Layer ────────────────────────────────────────────────────
DATA_MCP_CMD=                          # MCP server command (e.g. python fraud_data_mcp.py ...)
DATA_MCP_URL=                          # MCP server URL (alternative to command)

# ── Persistence ───────────────────────────────────────────────────
COORDINATOR_DB=coordinator.db          # SQLite database path (default)
# DATABASE_URL=postgresql://...        # PostgreSQL connection string (production)

# ── Service Bus (optional — durable task queue) ───────────────────
# DATA_SERVICE_BUS_URL=                # Azure Service Bus connection string
# DATA_SERVICE_BUS_QUEUE=cognitive-core-tasks

# ── API Server ────────────────────────────────────────────────────
PORT=8080
